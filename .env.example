# ==============================================================================
# FORGE ENVIRONMENT VARIABLES SETUP
# ==============================================================================
# Copy this file to .env.local and fill in the values below.
# ⚠️ NEVER commit .env.local to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Find these in your Supabase Dashboard -> Project Settings -> API
# NEXT_PUBLIC_SUPABASE_URL is the Project URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY is the anon/public Project API key

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------------------------
# AUTHENTICATION CONFIGURATION INSTRUCTIONS
# ------------------------------------------------------------------------------
# 1. Email/Password Setup
#    - Supabase Dashboard -> Authentication -> Providers -> Email
#    - Enable Email login
#    - Set Minimum Password Length to 6
#    - Tip: Disabling "Confirm email" speeds up local development.
#
# 2. Redirect URLs Setup
#    - Supabase Dashboard -> Authentication -> URL Configuration
#    - Set Site URL to: http://localhost:3000
#    - Add to Redirect URLs: http://localhost:3000/callback
#    - Add your Vercel deployment URL here for production.
#
# 3. Google OAuth Setup
#    A. Google Cloud Console:
#       - Create a new project.
#       - Configure OAuth consent screen as "External".
#       - Create Credentials -> OAuth client ID (Application type: Web app).
#       - Authorized JavaScript origins: http://localhost:3000
#       - Authorized redirect URIs: https://<your-supabase-ref>.supabase.co/auth/v1/callback
#       - Copy the generated Client ID and Client Secret.
#
#    B. Supabase Dashboard:
#       - Authentication -> Providers -> Google
#       - Enable Google provider.
#       - Paste the Client ID and Client Secret.
#       - Save.
# ------------------------------------------------------------------------------
